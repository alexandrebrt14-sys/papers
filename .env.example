# === LLM APIs (cheapest models auto-selected in config.py) ===
OPENAI_API_KEY=sk-...                 # gpt-4o-mini: $0.15/$0.60 per MTok
ANTHROPIC_API_KEY=sk-ant-...          # claude-haiku-4-5: $0.80/$4.00 per MTok
GOOGLE_AI_API_KEY=AI...               # gemini-2.5-pro: $1.25/$5.00 per MTok
PERPLEXITY_API_KEY=pplx-...           # sonar: $1/$1 per MTok + $5/1K search
GROQ_API_KEY=gsk_...                  # llama-3.3-70b: $0.59/$0.79 per MTok (diversifica amostra)

# === SERP Data ===
BRAVE_API_KEY=BSA...                  # Brave Search API (free tier: 2K queries/mo)
SERPAPI_KEY=                          # Legacy fallback (optional)

# SERP overlap toggle (Onda 9 — 2026-04-19):
# Por padrão desligado para proteger cota mensal Brave (2.000 queries/mo).
# Ative quando tiver orçamento para rodar Módulo 3 (SERP vs IA).
ENABLE_SERP_OVERLAP=false

# === Persistência ===
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJ...

# === Notificações ===
RESEND_API_KEY=re_...                 # Email diário de relatório

# === Configuração ===
PAPERS_DB_PATH=data/papers.db
CACHE_TTL_HOURS=20                    # Skip identical queries within this window

# === Multi-Vertical ===
VERTICAL=fintech                      # Default vertical (fintech|varejo|saude|tecnologia)

# === Controle de LLMs obrigatórios (Onda 3 — garante balanceamento do cohort) ===
MANDATORY_LLMS=ChatGPT,Claude,Gemini,Perplexity,Groq
# Todos os 5 LLMs são obrigatórios por padrão. Se algum falhar, exit 1 (fail-loud).
# Override em dev: MANDATORY_LLMS=ChatGPT,Claude (só para debug rápido).

# === Controle de entidades fictícias (Onda 3 — calibração de false-positive) ===
INCLUDE_FICTIONAL_ENTITIES=true
# Quando true: entidades fictícias (Banco Floresta Digital, MegaStore Brasil, ...)
# são incluídas em queries "inclua X na lista" para medir taxa de falsos positivos.

# === Coorte de estudo (override — só se precisar customizar fintech legado) ===
# COHORT_ENTITIES=Nubank,PagBank,Cielo,Stone,Banco Inter,...,Banco Floresta Digital,FinPay Solutions
