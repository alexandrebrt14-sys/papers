# === LLM APIs (cheapest models auto-selected in config.py) ===
OPENAI_API_KEY=sk-...          # gpt-4o-mini: $0.15/$0.60 per MTok
ANTHROPIC_API_KEY=sk-ant-...   # haiku-4.5: $1.00/$5.00 per MTok
GOOGLE_AI_API_KEY=AI...        # gemini-2.5-flash: $0.15/$0.60 per MTok (billing Cloud ativo)
PERPLEXITY_API_KEY=pplx-...    # sonar: $1/$1 per MTok + $5/1K search

# === SERP Data (Brave = free 2K queries/mo, replaces SerpAPI $50/mo) ===
BRAVE_API_KEY=BSA...           # https://brave.com/search/api/ (free tier)
SERPAPI_KEY=                   # Legacy fallback (optional)

# === Persistência ===
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJ...

# === Configuração ===
PAPERS_DB_PATH=data/papers.db
CACHE_TTL_HOURS=20             # Skip identical queries within this window

# === Multi-Vertical ===
VERTICAL=fintech               # Default vertical (fintech|varejo|saude|tecnologia)

# === Coorte de estudo (override — só se precisar customizar fintech) ===
